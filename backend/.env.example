# Groq API (gratuit sur console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email (formulaire de contact)
# Option 1 : Gmail — activez "Mots de passe d'application" dans votre compte Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre@gmail.com
EMAIL_PASS=votre_mot_de_passe_application

# Email de destination (où vous recevez les contacts)
EMAIL_TO=votre@email.com

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173

PORT=3001
